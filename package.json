{
  "name": "@easyai/cli",
  "version": "1.1.0",
  "description": "Stop wrestling with AI code. Unified prompts, real-time costs, model switching, and IDE integration.",
  "main": "src/index.js",
  "bin": {
    "easyai": "./bin/cli.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "lint": "eslint src/",
    "build": "echo 'No build step needed for Node.js server'",
    "db:init": "node -e \"require('./src/models').initializeDatabase()\"",
    "install:all": "npm install && cd dashboard && npm install",
    "setup-ide": "node install-ide-integration.js",
    "setup": "node bin/cli.js setup",
    "postinstall": "echo '\\n🎯 After getting your API key, run: easyai setup'"
  },
  "keywords": [
    "ai",
    "llm",
    "prompts",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "cost-tracking",
    "model-switching",
    "ide-integration",
    "cursor",
    "claude-code",
    "prompt-management",
    "ai-development"
  ],
  "author": "EasyAI Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "easyai": "^1.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "helmet": "^7.0.0",
    "inquirer": "^9.2.8",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.0",
    "ora": "^7.0.1",
    "sequelize": "^6.32.1",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "eslint": "^8.45.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
